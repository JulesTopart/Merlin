// --- SPH Routines ---
float calculateSolidDelta(uint gid) {
	float density = 0.0;
	Particle pk = particles[gid];
	
	OVERNNS
		Particle pj = particles[j];
		vec4 diff = vec4(pk.position) - vec4(pj.position);
		float rSquared = dot(diff, diff);
		if(pj.phase == SOLID) density += poly6(diff); //Neigbord Solid
	OVERNNS_END
	return density;
}

// SPH_Density_neighbor
float calculateDensity(uint gid, vec4 pposition) {
	float density = 0.0;
	
	OVERNNS
		Particle pj = particles[j];
		vec4 diff = pposition - pj.position;
		float rSquared = dot(diff, diff);
		if(pj.phase == LIQUID) density += particleMass * poly6(diff); //Fluid
		else if(pj.phase == SOLID){
			float volume_k = 1.0/pj.density;
			density += REST_DENSITY * volume_k * poly6(diff); //Fluid
		}
	OVERNNS_END
	

	return density;
}




// Introduce the viscosity constraint and its gradient
float viscosityConstraint(vec4 p_i, vec4 p_j, float d_ij) {
    return d_ij - length(p_i - p_j) - alpha * d_ij;
}

vec4 viscosityConstraintGradient(vec4 p_i, vec4 p_j) {
    vec4 p_ij = p_i - p_j;
    return normalize(p_ij);
}

