void XPBDSolve(uint gid, uint simStep) {
	

	if(simStep == 0){ //Neighbor search
		particles[gid].binIndex = getBinIndex(particles[gid].position);
		atomicAdd(bins[particles[gid].binIndex].count, 1);
		return;

	}else if(simStep == 1){ //Particle sort
		uint sortedPosition = atomicAdd(bins[particles[gid].binIndex].index, -1) -1;
		particles[sortedPosition].newIndex = gid;
		return;

	}else if(simStep == 2){ //Calculate Density
		particles[gid].density = calculateDensity(gid, particles[gid].position);
		return;
	}

	Particle p = particles[gid];
	if(p.phase == SOLID || p.phase == BOUNDARY) return;
		
	if(simStep == 3){ //Compute lambda --- 	//Solver iteration
