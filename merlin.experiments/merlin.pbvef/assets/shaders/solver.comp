// --- SPH Routines ---
float calculateSolidDelta(uint gid) {
	float delta = 0.0;
	Particle pi = particles[gid];
	
	OVERNNS
		Particle pk = particles[j];
		if(pk.phase != SOLID) continue;
		vec4 diff = vec4(pi.position) - vec4(pk.position);
		float rSquared = dot(diff, diff);
		delta += poly6(diff); //Neigboring Solid
	OVERNNS_END
	return delta;
}

// SPH_Density_neighbor
float calculateDensity(uint gid, vec4 pposition) {
	float density = 0.0;
	
	OVERNNS
		Particle pj = particles[j];
		vec4 diff = pposition - pj.position;
		float rSquared = dot(diff, diff);
		//density += poly6(diff); //Fluid
		particleMass * poly6(diff); //Fluid

	OVERNNS_END
	
	return  density;
}




// Introduce the viscosity constraint and its gradient
float viscosityConstraint(vec4 p_i, vec4 p_j, float d_ij) {
    return d_ij - length(p_i - p_j) - alpha * d_ij;
}

vec4 viscosityConstraintGradient(vec4 p_i, vec4 p_j) {
    vec4 p_ij = p_i - p_j;
    return normalize(p_ij);
}

