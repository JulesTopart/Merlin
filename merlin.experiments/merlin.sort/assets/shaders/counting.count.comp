#include "common.glsl"

const uint wgSize = 1; //WorkGroup size
layout(local_size_x = wgSize) in;

uniform uint stage;

void main(){
    uint gid = gl_GlobalInvocationID.x; //blockID

    if(stage == 0)
    if(gid < dataSize) atomicAdd(globalPrefixSum[outData[gid]],1);

    if(stage == 1)
    if(gid < dataSize) outData[globalPrefixSum[inData[gid]]-1] = inData[gid];
}